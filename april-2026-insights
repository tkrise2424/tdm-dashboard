  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f2f5; color: #1a1a2e; }

    .header {
      background: linear-gradient(135deg, #0d1b2a 0%, #1b3a5c 100%);
      color: #fff;
      padding: 40px 48px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .header .logo { font-size: 20px; font-weight: 700; letter-spacing: 1px; color: #4fc3f7; }
    .header h1 { font-size: 26px; font-weight: 700; margin-top: 6px; }
    .header .meta { font-size: 13px; color: #90caf9; margin-top: 4px; }
    .header .badge {
      background: #4fc3f7; color: #0d1b2a;
      font-size: 12px; font-weight: 700;
      padding: 6px 16px; border-radius: 20px;
      text-transform: uppercase; letter-spacing: 1px;
    }

    .container { max-width: 1280px; margin: 0 auto; padding: 36px 24px; }

    .section { margin-bottom: 44px; }
    .section-title {
      font-size: 12px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 1.5px;
      color: #4fc3f7; margin-bottom: 18px;
      padding-bottom: 8px; border-bottom: 2px solid #e0e7ef;
    }

    /* KPI Cards */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 14px; }
    .kpi-card {
      background: #fff; border-radius: 12px;
      padding: 20px 18px; box-shadow: 0 2px 8px rgba(0,0,0,0.07);
      border-top: 4px solid #4fc3f7;
    }
    .kpi-card.green  { border-top-color: #43a047; }
    .kpi-card.orange { border-top-color: #fb8c00; }
    .kpi-card.purple { border-top-color: #7e57c2; }
    .kpi-card.red    { border-top-color: #e53935; }
    .kpi-card.teal   { border-top-color: #00897b; }
    .kpi-card.gray   { border-top-color: #90a4ae; }
    .kpi-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #999; margin-bottom: 8px; }
    .kpi-value { font-size: 32px; font-weight: 800; color: #0d1b2a; line-height: 1; }
    .kpi-sub   { font-size: 11px; color: #aaa; margin-top: 6px; line-height: 1.4; }
    .kpi-src   { font-size: 10px; color: #bbb; margin-top: 4px; font-style: italic; }

    /* AI Insights */
    .insights-box {
      background: linear-gradient(135deg, #0d1b2a 0%, #1b3a5c 100%);
      color: #fff; border-radius: 12px;
      padding: 30px 34px; box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    }
    .insights-box p { font-size: 14.5px; line-height: 1.8; color: #cfe8ff; margin-bottom: 14px; }
    .insights-box p:last-child { margin-bottom: 0; }
    .insights-box strong { color: #4fc3f7; }

    /* Funnel */
    .funnel-wrap {
      background: #fff; border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.07);
      overflow: hidden;
    }
    .funnel-grid { display: grid; grid-template-columns: repeat(5, 1fr); }
    .funnel-step {
      padding: 26px 14px; text-align: center;
      border-right: 1px solid #f0f2f5;
      position: relative;
    }
    .funnel-step:last-child { border-right: none; }
    .funnel-step::after {
      content: '›'; position: absolute;
      right: -8px; top: 50%; transform: translateY(-50%);
      font-size: 22px; color: #ccc; z-index: 2;
    }
    .funnel-step:last-child::after { display: none; }
    .funnel-step.hl { background: #f0f7ff; }
    .f-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #888; margin-bottom: 10px; }
    .f-value { font-size: 30px; font-weight: 800; color: #0d1b2a; }
    .f-rate  { font-size: 12px; color: #4fc3f7; font-weight: 600; margin-top: 4px; }
    .f-sub   { font-size: 11px; color: #aaa; margin-top: 4px; line-height: 1.4; }

