    .rep-role  { font-size: 11px; color: #888; }
    .rep-row   { display: flex; justify-content: space-between; align-items: center; padding: 6px 0; border-bottom: 1px solid #f5f5f5; font-size: 13px; }
    .rep-row:last-child { border-bottom: none; }
    .rep-row .rl { color: #666; }
    .rep-row .rv { font-weight: 700; color: #0d1b2a; }
