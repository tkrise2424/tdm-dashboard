    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #f7faff; }
    tbody tr.total-row { background: #f0f7ff; font-weight: 700; }
    tbody td { padding: 11px 14px; color: #333; }
    tbody td.r { text-align: right; font-weight: 600; }
    tbody td.bold { font-weight: 700; }

    .tag {
      display: inline-block; padding: 2px 9px;
      border-radius: 10px; font-size: 10px;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    }
    .tag.top    { background: #e8f5e9; color: #1b5e20; }
    .tag.strong { background: #e3f2fd; color: #0d47a1; }
    .tag.solid  { background: #f3e5f5; color: #4a148c; }
    .tag.flat   { background: #f3f4f6; color: #666; }
    .tag.low    { background: #fff3e0; color: #e65100; }
    .tag.gap    { background: #ffebee; color: #b71c1c; }
    .tag.active { background: #e8f5e9; color: #2e7d32; }
    .tag.new    { background: #e3f2fd; color: #1565c0; }
    .tag.done   { background: #f3f4f6; color: #555; }

    /* Rep breakdown */
