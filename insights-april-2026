<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>TDM Performance Dashboard — April 2026</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f0f2f5; color: #1a1a2e; }

    .header {
      background: linear-gradient(135deg, #0d1b2a 0%, #1b3a5c 100%);
      color: #fff;
      padding: 40px 48px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .header .logo { font-size: 22px; font-weight: 700; letter-spacing: 1px; color: #4fc3f7; }
    .header h1 { font-size: 26px; font-weight: 700; margin-top: 6px; }
    .header .meta { font-size: 13px; color: #90caf9; margin-top: 4px; }
    .header .badge {
      background: #4fc3f7;
      color: #0d1b2a;
      font-size: 12px;
      font-weight: 700;
      padding: 6px 14px;
      border-radius: 20px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .container { max-width: 1200px; margin: 0 auto; padding: 36px 24px; }

    .section-title {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: #4fc3f7;
      margin-bottom: 16px;
      padding-bottom: 8px;
      border-bottom: 2px solid #e0e7ef;
    }

    .section { margin-bottom: 40px; }

    /* KPI Cards */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 16px;
      margin-bottom: 8px;
    }
    .kpi-card {
      background: #fff;
      border-radius: 12px;
      padding: 22px 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.07);
      border-top: 4px solid #4fc3f7;
    }
    .kpi-card.green { border-top-color: #43a047; }
    .kpi-card.orange { border-top-color: #fb8c00; }
    .kpi-card.purple { border-top-color: #7e57c2; }
    .kpi-card.red { border-top-color: #e53935; }
    .kpi-card.teal { border-top-color: #00897b; }
    .kpi-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #888; margin-bottom: 8px; }
    .kpi-value { font-size: 30px; font-weight: 800; color: #0d1b2a; line-height: 1; }
    .kpi-sub { font-size: 12px; color: #aaa; margin-top: 6px; }

    /* AI Insights box */
    .insights-box {
      background: linear-gradient(135deg, #0d1b2a 0%, #1b3a5c 100%);
      color: #fff;
      border-radius: 12px;
      padding: 28px 32px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.12);
    }
    .insights-box p { font-size: 15px; line-height: 1.75; color: #cfe8ff; }
    .insights-box strong { color: #4fc3f7; }

    /* Tables */
    .table-wrap { background: #fff; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.07); overflow: hidden; }
    table { width: 100%; border-collapse: collapse; font-size: 14px; }
    thead tr { background: #0d1b2a; color: #fff; }
    thead th { padding: 13px 16px; text-align: left; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; }
    tbody tr { border-bottom: 1px solid #f0f2f5; }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #f7faff; }
    tbody td { padding: 12px 16px; color: #333; }
    tbody td.num { text-align: right; font-weight: 600; }
    .tag {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 12px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .tag.up { background: #e8f5e9; color: #2e7d32; }
    .tag.flat { background: #f3f4f6; color: #888; }
    .tag.down { background: #ffebee; color: #c62828; }
    .tag.new { background: #e3f2fd; color: #1565c0; }

    /* Funnel */
    .funnel-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      background: #fff;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(0,0,0,0.07);
    }
    .funnel-step {
      padding: 28px 16px;
      text-align: center;
      border-right: 1px solid #f0f2f5;
      position: relative;
    }
    .funnel-step:last-child { border-right: none; }
    .funnel-step::after {
      content: '→';
      position: absolute;
      right: -10px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 18px;
      color: #ccc;
      z-index: 2;
    }
    .funnel-step:last-child::after { display: none; }
    .funnel-step .f-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: #888; margin-bottom: 10px; }
    .funnel-step .f-value { font-size: 28px; font-weight: 800; color: #0d1b2a; }
    .funnel-step .f-rate { font-size: 12px; color: #4fc3f7; font-weight: 600; margin-top: 4px; }
    .funnel-step .f-sub { font-size: 11px; color: #aaa; margin-top: 4px; }
    .funnel-step.active { background: #f0f7ff; }

    /* Observations */
    .obs-list { list-style: none; }
    .obs-list li {
      background: #fff;
      border-radius: 10px;
      padding: 16px 20px;
      margin-bottom: 12px;
      box-shadow: 0 1px 6px rgba(0,0,0,0.06);
      display: flex;
      align-items: flex-start;
      gap: 14px;
      font-size: 14px;
      line-height: 1.6;
      color: #333;
    }
    .obs-list li .icon { font-size: 20px; flex-shrink: 0; margin-top: 1px; }

    /* Optimization / Change cards */
    .card-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 16px; }
    .action-card {
      background: #fff;
      border-radius: 12px;
      padding: 22px 22px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.07);
      border-left: 5px solid #4fc3f7;
    }
    .action-card.green { border-left-color: #43a047; }
    .action-card.orange { border-left-color: #fb8c00; }
    .action-card.purple { border-left-color: #7e57c2; }
    .action-card.red { border-left-color: #e53935; }
    .action-card h4 { font-size: 14px; font-weight: 700; color: #0d1b2a; margin-bottom: 8px; }
    .action-card p { font-size: 13px; color: #555; line-height: 1.6; }
    .action-card .expected { font-size: 12px; color: #4fc3f7; font-weight: 600; margin-top: 10px; }
    .action-card.green .expected { color: #43a047; }
    .action-card.orange .expected { color: #fb8c00; }
    .action-card.purple .expected { color: #7e57c2; }

    /* Channel breakdown row */
    .channel-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .footer {
      text-align: center;
      padding: 28px;
      font-size: 12px;
      color: #aaa;
      border-top: 1px solid #e0e7ef;
      margin-top: 20px;
    }
    .footer strong { color: #4fc3f7; }

    @media (max-width: 768px) {
      .funnel-grid { grid-template-columns: 1fr 1fr; }
      .channel-row { grid-template-columns: 1fr; }
      .header { flex-direction: column; gap: 16px; text-align: center; }
    }
  </style>
</head>
